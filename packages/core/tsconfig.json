{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": false,
    "stripInternal": true,
    "importHelpers": false,
    "preserveSymlinks": false,
    "newLine": "lf",
    "pretty": false,
    "noEmitOnError": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "src"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test"
  ]
}
