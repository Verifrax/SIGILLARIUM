{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "declaration": false,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "./vendor/*": [
        "../cli/vendor/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
