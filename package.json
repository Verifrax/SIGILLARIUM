{
  "name": "@verifrax/sigillarium",
  "private": false,
  "version": "0.1.2",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm --workspaces --if-present run build",
    "test": "npm --workspaces --if-present test",
    "lint": "npm --workspaces --if-present run lint"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "typescript": "^5.9.3"
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Verifrax/SIGILLARIUM.git"
  },
  "homepage": "https://github.com/Verifrax/SIGILLARIUM#readme",
  "bugs": {
    "url": "https://github.com/Verifrax/SIGILLARIUM/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "package.json",
    "LICENSE",
    "README.md",
    "packages/core/package.json",
    "packages/core/LICENSE",
    "packages/core/README.md",
    "packages/core/src",
    "packages/core/tsconfig.json",
    "packages/core/VERSIONING.md",
    "packages/cli/package.json",
    "packages/cli/LICENSE",
    "packages/cli/README.md",
    "packages/cli/src",
    "packages/cli/scripts",
    "packages/cli/tsconfig.json",
    "packages/cli/vendor/core/dist"
  ]
}
